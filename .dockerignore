# Exclude everything by default
**

# Only include the parcel subfolder (the Spring Boot project)
!parcel/

# Inside the parcel subfolder, exclude the target and logs
parcel/target/
parcel/logs/

# Exclude common temporary files
.git/
.vscode/
.github/
*.log
.DS_Store
.idea/
*.iml
.classpath
.project
.settings/
HELP.md
bin/
